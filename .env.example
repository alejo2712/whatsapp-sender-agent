# ─────────────────────────────────────────────────
# Mode: mock | live
# ─────────────────────────────────────────────────
# mock (default) — no credentials needed. Simulates a successful API response.
# live           — requires META_* credentials below.
WHATSAPP_MODE=mock

# ─────────────────────────────────────────────────
# Meta WhatsApp Cloud API credentials
# Required only when WHATSAPP_MODE=live
# See docs/meta-whatsapp-setup.md for instructions.
# Never commit this file once populated.
# ─────────────────────────────────────────────────
META_ACCESS_TOKEN=your_permanent_or_temporary_access_token_here
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_GRAPH_API_VERSION=v21.0
