{
  "name": "whatsapp-sender-agent",
  "version": "0.1.0",
  "description": "CLI agent for sending WhatsApp messages via Meta Cloud API. Designed to be invoked by orchestrators, n8n workflows, or REST APIs.",
  "type": "module",
  "bin": {
    "whatsapp-sender": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "send": "tsx src/cli.ts send",
    "send:template": "tsx src/cli.ts send:template",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
